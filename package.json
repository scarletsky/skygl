{
  "name": "skygl",
  "version": "0.0.1",
  "description": "Yet another WebGL engine.",
  "main": "dist/skygl.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "rollup --config --watch --environment TARGET:dev",
    "build": "rm -rf dist/ && rollup --config --environment TARGET:cjs",
    "test": "jest"
  },
  "author": "scarletsky <scarletsky1025@gmail.com> (https://github.com/scarletsky)",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^23.1.5",
    "jest": "^23.3.0",
    "rollup": "^1.10.1",
    "rollup-plugin-json": "^4.0.0",
    "rollup-plugin-serve": "^1.0.0",
    "rollup-plugin-typescript": "^1.0.1",
    "ts-jest": "^23.0.0",
    "typescript": "^3.4.5"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "(/tests/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "modulePaths": [
      "<rootDir>/src"
    ],
    "globals": {
      "ts-jest": {
        "skipBabel": true
      }
    }
  },
  "dependencies": {
    "tslib": "^1.9.3"
  }
}
